{
  "name": "giaodich-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc --noEmit",
    "seed:vgreen": "tsx scripts/seed-vgreen-electric-bills.ts",
    "seed:vouchers": "tsx scripts/seed-voucher-codes.ts",
    "docker:dump-mongo-seed": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dump-local-mongo-to-seed.ps1",
    "docker:restore-mongo-seed": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/restore-mongo-seed-to-docker.ps1"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.14.0",
    "openai": "^4.96.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "dotenv": "^16.4.7",
    "tsx": "^4.19.3",
    "typescript": "^5"
  }
}
