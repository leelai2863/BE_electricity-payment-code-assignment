{
  "name": "giaodich-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc --noEmit",
    "seed:billing": "tsx scripts/import-billing-from-xlsx.ts",
    "docker:restore-mongo-seed": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/restore-mongo-seed-to-docker.ps1",
    "docker:seed": "docker exec giaodich-backend sh -c \"cd /app && npx tsx scripts/seed-vgreen-electric-bills.ts && npx tsx scripts/seed-voucher-codes.ts\"",
    "docker:prod:up": "docker compose -f docker-compose.prod.yml up -d --build",
    "docker:prod:down": "docker compose -f docker-compose.prod.yml down",
    "migrate:normalize-evn-period-slots": "tsx scripts/normalize-evn-period-slots.ts"
  },
  "dependencies": {
    "@core-x/shared-logger": "file:./packages/shared-logger",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.14.0",
    "multer": "^2.1.1",
    "openai": "^4.96.0",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^20",
    "dotenv": "^16.4.7",
    "tsx": "^4.19.3",
    "typescript": "^5"
  }
}
