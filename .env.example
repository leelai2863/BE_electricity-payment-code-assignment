# Mongo trên máy (npm run dev): nếu chỉ dùng Mongo trong Docker, Compass/host dùng cổng publish — mặc định 27018 (xem docker-compose MONGO_HOST_PORT).
MONGODB_URI=mongodb://localhost:27018/giaodich_voucher
# Chỉ dùng khi docker compose cần đổi cổng host (mặc định 27018 trong compose).
MONGO_HOST_PORT=27018
OPENAI_API_KEY=sk-...
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_TEXT_MODEL=gpt-4o-mini
PORT=3001
CORS_ORIGIN=http://localhost:3000
