{
  "name": "@core-x/shared-logger",
  "version": "1.0.0",
  "description": "Shared structured logger with RabbitMQ producer for Core-X microservices",
  "license": "UNLICENSED",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
